{
  "name": "vjn-billing-desktop",
  "version": "1.0.0",
  "description": "Desktop application for VJN Billing System",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "dev": "npm run start",
    "prepare-backend": "npm --prefix ../backend run bundle",
    "build": "npm run prepare-backend && npm run react-build && electron-builder",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "wait-on": "^7.0.0"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.vjn.billing",
    "productName": "VJN Billing System",
    "compression": "maximum",
    "asar": true,
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "!**/*.map",
      "!src/**/*"
    ],
    "extraMetadata": {
      "main": "build/electron.js"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "buildResources": "public"
    },
    "icon": "public/icon",
    "extraFiles": [
      {
        "from": "../backend/dist/server.bundle.cjs",
        "to": "backend/server.bundle.cjs"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/node_modules/better-sqlite3",
        "to": "backend/node_modules/better-sqlite3",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/node_modules/bindings",
        "to": "backend/node_modules/bindings",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/node_modules/file-uri-to-path",
        "to": "backend/node_modules/file-uri-to-path",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "icon": "public/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "sign": false,
      "identity": null
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  }
}
